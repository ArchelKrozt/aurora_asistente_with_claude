                                self.cfg.set('current_account_idx', 0)
                            self.cfg.save_all({'accounts': accs2})
                            refresh_accounts_ui()
                    del_btn.connect('clicked', on_del)
                    row_box.pack_start(del_btn, False, False, 0)

