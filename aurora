def _run_claude_image(image_path: str, prompt: str, cfg: Config,
                      claude_dir: str | None = None) -> tuple[str, str]:
    """Envía imagen + texto al CLI via stream-json (base64)."""
    with open(image_path, 'rb') as f:
        b64 = base64.b64encode(f.read()).decode()

    content = [
        {'type': 'image', 'source': {'type': 'base64',
                                     'media_type': 'image/png', 'data': b64}},
        {'type': 'text',  'text': prompt or 'Describe y analiza esta imagen.'},
    ]
    user_block = json.dumps({
        'type': 'user',
        'message': {'role': 'user', 'content': content},
    })

    env = {**os.environ, 'PATH': _ext_path()}
    if claude_dir:
        env['CLAUDE_CONFIG_DIR'] = claude_dir

    args = [CLAUDE_BIN, '--print', '--output-format', 'json',
            '--input-format', 'stream-json',
            '--append-system-prompt', cfg.get('personality', '')]

    result = subprocess.run(args, input=user_block + '\n',
                            capture_output=True, text=True, timeout=180, env=env)
    if result.returncode != 0:
        err = (result.stderr or result.stdout or '').strip()
        raise RuntimeError(f'Image CLI error: {err[:300]}')

    # El output puede tener varias líneas JSON; buscar la que tiene 'result'
    for line in reversed(result.stdout.strip().splitlines()):
        try:
            d = json.loads(line)
            if d.get('result'):
                return d['result'], d.get('session_id', '')
        except Exception:
            pass
    raise RuntimeError('No se pudo parsear respuesta con imagen')


def _run_claude(message: str, session_id: str | None,
                cfg: Config, claude_dir: str | None = None,
                on_compact=None) -> tuple[str, str]:
    """Llama al CLI de Claude con stream-json para detectar compactación."""
    env = {**os.environ, 'PATH': _ext_path()}
    if claude_dir:
        env['CLAUDE_CONFIG_DIR'] = claude_dir

    args = [CLAUDE_BIN, '--print', '--verbose', '--output-format', 'stream-json',
            '--append-system-prompt', cfg.get('personality', '')]
    if session_id:
        args += ['--resume', session_id]
    model = cfg.get('model')
    if model:
        args += ['--model', model]
    args.append(message)

    proc = subprocess.Popen(args, stdout=subprocess.PIPE, stderr=subprocess.PIPE,
                            text=True, env=env, bufsize=1)

    full_result = ''
    new_sid     = session_id or ''
    compacting  = False
    last_ts     = time.time()

    try:
        for raw in proc.stdout:
            last_ts = time.time()
            line = raw.strip()
            if not line:
                continue
            try:
                ev = json.loads(line)
            except json.JSONDecodeError:
                continue

            ev_type = ev.get('type', '')
            ev_sub  = ev.get('subtype', '')

            # Detectar evento de compactación
            is_compact_ev = (
                ev_type in ('compact', 'compaction') or
                ev_sub  in ('compact', 'compaction', 'compacted', 'summary') or
                ('compact' in ev_type.lower()) or
                (ev_type == 'system' and 'compact' in str(ev).lower())
            )
            if is_compact_ev and not compacting:
                compacting = True
                if on_compact:
                    on_compact(True)

            if ev_type == 'result':
                if ev.get('is_error'):
                    raise RuntimeError(ev.get('result', 'Error desconocido'))
                full_result = ev.get('result', '')
                new_sid     = ev.get('session_id', new_sid)
                break

        proc.wait(timeout=10)
    except Exception:
        proc.kill()
        raise
    finally:
        if compacting and on_compact:
            on_compact(False)

    if proc.returncode != 0 and not full_result:
        err = (proc.stderr.read() if proc.stderr else '').strip()
        raise RuntimeError(f"CLI error ({proc.returncode}): {err[:300]}")
    return full_result, new_sid


def call_claude(message: str, session_id: str | None,
                cfg: Config, on_compact=None) -> tuple[str, str, str]:
    """
    Llama a claude con failover automático entre cuentas.
    Retorna (respuesta, session_id, label_cuenta_usada).
    """
    accounts = cfg.get('accounts', [])
    if not accounts:
        # Primera vez: migrar automáticamente con la cuenta actual
        accounts = default_accounts()
        cfg.set('accounts', accounts)

    now = datetime.now().timestamp()
    start = cfg.get('current_account_idx', 0) or 0
    n     = len(accounts)
    tried = 0

    for i in range(n):
        idx = (start + i) % n
        acc = accounts[idx]
        if not acc.get('enabled', True):
            continue
        dep = acc.get('depleted_until')
        if dep and now < dep:
            continue

        tried += 1
        claude_dir = acc.get('claude_dir')
        try:
            resp, sid = _run_claude(message, session_id, cfg, claude_dir,
                                   on_compact=on_compact)
            # Si cambiamos de cuenta, actualizar índice activo
            if idx != start:
                cfg.set('current_account_idx', idx)
            return resp, sid, acc.get('label', f'Cuenta {idx+1}')
        except RuntimeError as e:
            if _is_rate_limit(str(e)):
                # Marcar agotada por 1 hora y probar siguiente
                accounts[idx]['depleted_until'] = now + 3600
                cfg.save_all({'accounts': accounts})
                continue
            raise

    if tried == 0:
        raise RuntimeError('No hay cuentas habilitadas.')
    raise RuntimeError('Todas las cuentas están agotadas o sin tokens. '
                       'Prueba de nuevo en una hora o agrega otra cuenta.')


