    def _terminal_worker(self, cmd: str, use_sudo: bool):
        try:
            if use_sudo:
                output, rc = SUDO_MGR.run(cmd)
            else:
                result = subprocess.run(
                    cmd, shell=True, capture_output=True, text=True,
                    timeout=60, env={**os.environ, 'PATH': _ext_path()})
                output = (result.stdout + result.stderr).strip() or '(sin output)'
                rc     = result.returncode

            GLib.idle_add(self._show_terminal_output, cmd, output, rc, use_sudo)
        except subprocess.TimeoutExpired:
            GLib.idle_add(self._show_terminal_output, cmd,
                          '[timeout: el comando tardó más de 60s]', -1, use_sudo)
        except Exception as e:
            GLib.idle_add(self._show_terminal_output, cmd, str(e), -1, use_sudo)

