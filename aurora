    # ── Barra de compactación ──────────────────────────────────────
    def _show_compact_bar(self):
        """Muestra barra cyberpunk de compactación sobre el área de chat."""
        if hasattr(self, '_compact_bar_widget') and self._compact_bar_widget:
            return  # ya visible

        bar = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=2)
        bar.get_style_context().add_class('compact-bar')

        lbl = Gtk.Label()
        lbl.get_style_context().add_class('compact-lbl')
        lbl.set_markup('◈  COMPACTANDO MEMORIA NEURAL  ◈')
        lbl.set_halign(Gtk.Align.CENTER)
        bar.pack_start(lbl, False, False, 0)

        # track (fondo) + fill (progreso animado)
        track = Gtk.DrawingArea()
        track.get_style_context().add_class('compact-track')
        track.set_size_request(-1, 7)

        self._compact_fill_w  = track
        self._compact_phase   = 0.0   # 0.0–1.0 animado en loop
        self._compact_dir     = 1
        bar.pack_start(track, False, False, 0)

        track.connect('draw', self._compact_draw)

        # segunda fila: bloques parpadeantes
        blk_box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=3)
        blk_box.set_halign(Gtk.Align.CENTER)
        self._compact_blocks = []
        for _ in range(12):
            b = Gtk.Label(label='█')
            b.get_style_context().add_class('compact-lbl')
            blk_box.pack_start(b, False, False, 0)
            self._compact_blocks.append(b)
        bar.pack_start(blk_box, False, False, 2)

        self._compact_bar_widget = bar
        # insertar al principio del chat_box
        self._chat_box.pack_start(bar, False, False, 0)
        self._chat_box.reorder_child(bar, 0)
        bar.show_all()

        self._compact_timer = GLib.timeout_add(60, self._compact_tick)
        return False

    def _compact_draw(self, widget, ctx):
        """Cairo draw: barra de progreso bouncing."""
        w = widget.get_allocated_width()
        h = widget.get_allocated_height()
        acc = self.cfg.get('accent', C_YELLOW).lstrip('#')
        r = int(acc[0:2], 16) / 255
        g = int(acc[2:4], 16) / 255
        b = int(acc[4:6], 16) / 255
        # fondo
        ctx.set_source_rgba(r, g, b, 0.10)
        ctx.rectangle(0, 0, w, h)
        ctx.fill()
        # bloque deslizante
        fill_w = max(30, w // 3)
        x = int(self._compact_phase * (w - fill_w))
        ctx.set_source_rgba(r, g, b, 0.85)
        ctx.rectangle(x, 0, fill_w, h)
        ctx.fill()
        # brillo
        ctx.set_source_rgba(1, 1, 1, 0.25)
        ctx.rectangle(x, 0, 4, h)
        ctx.fill()

    def _compact_tick(self):
        if not hasattr(self, '_compact_bar_widget') or not self._compact_bar_widget:
            return False
        # animar barra bouncing
        self._compact_phase += 0.035 * self._compact_dir
        if self._compact_phase >= 1.0:
            self._compact_phase = 1.0; self._compact_dir = -1
        elif self._compact_phase <= 0.0:
            self._compact_phase = 0.0; self._compact_dir = 1
        if self._compact_fill_w:
            self._compact_fill_w.queue_draw()
        # bloques parpadeantes
        for b in self._compact_blocks:
            b.set_opacity(0.2 + random.random() * 0.8)
        return True

    def _hide_compact_bar(self):
        if hasattr(self, '_compact_bar_widget') and self._compact_bar_widget:
            self._chat_box.remove(self._compact_bar_widget)
            self._compact_bar_widget = None
        if hasattr(self, '_compact_timer') and self._compact_timer:
            GLib.source_remove(self._compact_timer)
            self._compact_timer = None
        return False

    # ── Historial ──────────────────────────────────────────────────
    def _show_history(self, *_):
        dlg = Gtk.Dialog(title='Historial', parent=self, modal=True)
        dlg.set_default_size(440, 420)

        # búsqueda
        search_ent = Gtk.SearchEntry()
        search_ent.set_placeholder_text('Buscar conversación…')
        search_ent.set_margin_top(6); search_ent.set_margin_bottom(4)
        search_ent.set_margin_start(10); search_ent.set_margin_end(10)
        dlg.get_content_area().pack_start(search_ent, False, False, 0)

        lb = Gtk.ListBox()
        lb.set_selection_mode(Gtk.SelectionMode.SINGLE)

        all_convs = [list(c.items()) for c in Conversation.list_all()]  # lista mutable

        def _make_row(c: dict):
            r = Gtk.ListBoxRow()
            r.cid = c['id']
            r.get_style_context().add_class('dlg-row')

            # overlay para mostrar botones al hacer hover
            overlay = Gtk.Overlay()
            r.add(overlay)

            # contenido principal
            hb = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=0)
            hb.set_margin_top(5); hb.set_margin_bottom(5)
            hb.set_margin_start(10); hb.set_margin_end(6)

            vb = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=2)
            tl = Gtk.Label(label=c['title'][:58])
            tl.get_style_context().add_class('dlg-title')
            tl.set_halign(Gtk.Align.START)
            tl.set_ellipsize(Pango.EllipsizeMode.END)
            tl.set_max_width_chars(40)
            dl = Gtk.Label(label=c['created'][:16].replace('T', '  '))
            dl.get_style_context().add_class('dlg-sub')
            dl.set_halign(Gtk.Align.START)
            vb.pack_start(tl, False, False, 0)
            vb.pack_start(dl, False, False, 0)
            hb.pack_start(vb, True, True, 0)

            # botones hover (ocultos por defecto)
            btn_box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=4)
            btn_box.set_valign(Gtk.Align.CENTER)
            btn_box.set_halign(Gtk.Align.END)
            btn_box.set_margin_end(8)
            btn_box.set_no_show_all(True)

            ren_btn = Gtk.Button(label='✎')
            ren_btn.get_style_context().add_class('hist-action-btn')
            ren_btn.set_tooltip_text('Renombrar')
            del_btn = Gtk.Button(label='✕')
            del_btn.get_style_context().add_class('hist-action-btn')
            del_btn.get_style_context().add_class('hist-del-btn')
            del_btn.set_tooltip_text('Eliminar')
            btn_box.pack_start(ren_btn, False, False, 0)
            btn_box.pack_start(del_btn, False, False, 0)

            overlay.add(hb)
            overlay.add_overlay(btn_box)
            overlay.set_overlay_pass_through(btn_box, True)

            # hover: mostrar / ocultar botones
            def _enter(widget, event, bb=btn_box):
                bb.show_all()
            def _leave(widget, event, bb=btn_box):
                # solo ocultar si el cursor salió del row completo
                alloc = r.get_allocation()
                if not (0 <= event.x <= alloc.width and 0 <= event.y <= alloc.height):
                    bb.hide()

            r.add_events(Gdk.EventMask.ENTER_NOTIFY_MASK | Gdk.EventMask.LEAVE_NOTIFY_MASK)
            r.connect('enter-notify-event', _enter)
            r.connect('leave-notify-event', _leave)

            # renombrar
            def _rename(btn, row=r, title_lbl=tl, cid=c['id']):
                popup = Gtk.Dialog(title='Renombrar', parent=dlg, modal=True)
                popup.set_default_size(340, 80)
                ent = Gtk.Entry()
                ent.set_text(title_lbl.get_text())
                ent.set_margin_top(10); ent.set_margin_bottom(6)
                ent.set_margin_start(12); ent.set_margin_end(12)
                popup.get_content_area().pack_start(ent, False, False, 0)
                popup.add_button('Guardar', Gtk.ResponseType.OK)
                popup.add_button('Cancelar', Gtk.ResponseType.CANCEL)
                popup.show_all()
                ent.grab_focus()
                ent.connect('activate', lambda e: popup.response(Gtk.ResponseType.OK))
                if popup.run() == Gtk.ResponseType.OK:
                    new_name = ent.get_text().strip()
                    if new_name:
                        Conversation.rename(cid, new_name)
                        title_lbl.set_text(new_name[:58])
                        # actualizar lista interna
                        for entry in all_convs:
                            d = dict(entry)
                            if d.get('id') == cid:
                                entry[:] = list({**d, 'title': new_name}.items())
                popup.destroy()

            ren_btn.connect('clicked', _rename)

            # eliminar
            def _delete(btn, row=r, cid=c['id']):
                conf = Gtk.MessageDialog(
                    parent=dlg, modal=True,
                    message_type=Gtk.MessageType.WARNING,
                    buttons=Gtk.ButtonsType.YES_NO,
                    text='¿Eliminar esta conversación?')
                conf.format_secondary_text(c['title'][:60])
                resp = conf.run()
                conf.destroy()
                if resp == Gtk.ResponseType.YES:
                    Conversation.delete(cid)
                    lb.remove(row)
                    lb.show_all()

            del_btn.connect('clicked', _delete)

            return r

        all_convs_dicts = Conversation.list_all()

        def _build_rows(convs):
            for child in lb.get_children():
                lb.remove(child)
            for c in convs:
                lb.add(_make_row(c))
            lb.show_all()

        def _on_search(entry):
            q = entry.get_text().strip().lower()
            filtered = [c for c in all_convs_dicts if q in c['title'].lower()] if q else all_convs_dicts
            _build_rows(filtered)

        search_ent.connect('search-changed', _on_search)
        _build_rows(all_convs_dicts)

        sc = Gtk.ScrolledWindow()
        sc.set_vexpand(True)
        sc.add(lb)
        dlg.get_content_area().pack_start(sc, True, True, 4)
        dlg.add_button('Abrir',    Gtk.ResponseType.OK)
        dlg.add_button('Cancelar', Gtk.ResponseType.CANCEL)
        dlg.show_all()

        if dlg.run() == Gtk.ResponseType.OK:
            sel = lb.get_selected_row()
            if sel: self._load_conv(sel.cid)
        dlg.destroy()

