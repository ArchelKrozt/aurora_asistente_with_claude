    def _setup_global_hotkey(self):
        if not HAS_XLIB or not self.cfg.get('hotkey_enabled', True):
            return
        threading.Thread(target=self._hotkey_thread, daemon=True).start()

    def _hotkey_thread(self):
        try:
            d = Xdisplay.Display()
            # evitar que BadAccess llame a sys.exit()
            def _xlib_err(err, req): raise err
            d.set_error_handler(_xlib_err)
            root = d.screen().root
            code = d.keysym_to_keycode(XK.XK_space)
            mod  = X.ControlMask | X.Mod1Mask
            try:
                root.grab_key(code, mod, True, X.GrabModeAsync, X.GrabModeAsync)
                root.change_attributes(event_mask=X.KeyPressMask)
                d.sync()   # fuerza procesamiento de errores antes de next_event
            except Exception:
                return     # ya está capturada la tecla, ignorar
            while True:
                ev = d.next_event()
                if ev.type == X.KeyPress and ev.detail == code:
                    GLib.idle_add(self.toggle)
        except Exception:
            pass

