def read_account_creds(claude_dir: str) -> dict:
    """Lee credenciales de un directorio CLAUDE_CONFIG_DIR."""
    creds_path = Path(claude_dir) / '.credentials.json'
    if not creds_path.exists():
        return {}
    try:
        d = json.loads(creds_path.read_text())
        oauth = d.get('claudeAiOauth', {})
        return {
            'plan':  oauth.get('subscriptionType', '?'),
            'tier':  oauth.get('rateLimitTier', '?'),
            'valid': bool(oauth.get('accessToken')),
        }
    except Exception:
        return {}

