    def _reload_css(self):
        if self._css_provider:
            Gtk.StyleContext.remove_provider_for_screen(
                Gdk.Screen.get_default(), self._css_provider)
        self._css_provider = Gtk.CssProvider()
        self._css_provider.load_from_data(build_css(self.cfg))
        Gtk.StyleContext.add_provider_for_screen(
            Gdk.Screen.get_default(), self._css_provider,
            Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION + 20)

    # ── Posición ───────────────────────────────────────────────────
    def _position(self):
        display = Gdk.Display.get_default()
        monitor = display.get_monitor(0)
        geom    = monitor.get_geometry()
        w, _    = self.get_default_size()
        self.move(geom.x + geom.width - w - 6, geom.y + 32)

