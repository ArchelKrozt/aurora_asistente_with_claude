        ca.set_margin_top(12); ca.set_margin_bottom(8)
        ca.set_margin_start(14); ca.set_margin_end(14)
        ca.set_spacing(8)

        ca.pack_start(Gtk.Label(label='¿Cómo exportar?'), False, False, 0)
