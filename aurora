    def _show_boot_animation(self):
        if not self.cfg.get('boot_animation', True):
            return
        # Solo una vez por día
        today = datetime.now().strftime('%Y-%m-%d')
        last  = self.cfg.get('_last_boot_date', '')
        if last == today:
            return
        self.cfg.set('_last_boot_date', today)

        overlay = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        overlay.get_style_context().add_class('boot-overlay')
        overlay.set_hexpand(True); overlay.set_vexpand(True)

        tv = Gtk.TextView()
        tv.set_editable(False); tv.set_cursor_visible(False)
        tv.set_wrap_mode(Gtk.WrapMode.WORD)
        tv.set_left_margin(24); tv.set_right_margin(24)
        tv.set_top_margin(60)
        tv.get_style_context().add_class('boot-tv')
        buf = tv.get_buffer()
        overlay.pack_start(tv, True, True, 0)
        overlay.show_all()

        # Superponer sobre el contenido
        self._root_box.pack_start(overlay, True, True, 0)
        self._root_box.reorder_child(overlay, 0)

        lines   = list(self.BOOT_LINES)
        state   = {'i': 0, 'pos': 0, 'text': ''}

        def tick():
            if state['i'] >= len(lines):
                GLib.timeout_add(600, lambda: (
                    self._root_box.remove(overlay) or
                    overlay.destroy() or False))
                return False
            line = lines[state['i']]
            if state['pos'] <= len(line):
                chunk = line[state['pos']:state['pos'] + 3]
                state['text'] += chunk
                state['pos']  += 3
                buf.set_text(state['text'])
            else:
                state['text'] += '\n'
                state['i']   += 1
                state['pos']  = 0
            return True

        GLib.timeout_add(18, tick)

