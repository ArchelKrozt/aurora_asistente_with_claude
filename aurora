    def _do_screenshot(self, prompt: str, region: bool):
        try:
            raw = '/tmp/aurora_shot.png'
            display = Gdk.Display.get_default()
            monitor = display.get_monitor(0)
            geom    = monitor.get_geometry()
            subprocess.run([
                'ffmpeg', '-f', 'x11grab',
                '-video_size', f'{geom.width}x{geom.height}',
                '-i', ':0', '-frames:v', '1', '-update', '1', '-y', raw,
            ], capture_output=True, timeout=5)
        except Exception as e:
            GLib.idle_add(self._on_error, f'Captura fallida: {e}')
            GLib.idle_add(self.show_all)
            return False

        GLib.idle_add(self.show_all)
        GLib.idle_add(self.present)

        if Path(raw).exists():
            # Añadir mensaje del usuario mostrando que se capturó
            row, _ = _make_message_row(
                'user', f'[Captura de pantalla] {prompt or ""}',
                self.cfg, self._ai_pb, self._user_pb)
            GLib.idle_add(self._add_row, row)

            # Indicador
            typ_row, _ = _make_typing_indicator(self.cfg)
            GLib.idle_add(self._add_row, typ_row)
            GLib.idle_add(setattr, self, '_typing_row', typ_row)
            self._busy = True
            GLib.idle_add(self._btn.set_sensitive, False)
            GLib.idle_add(self._status.set_text, '📷 analizando captura…')

            threading.Thread(
                target=self._screenshot_worker,
                args=(raw, prompt or 'Describe en detalle qué ves en esta captura de pantalla.'),
                daemon=True).start()
        return False

    def _screenshot_worker(self, path: str, prompt: str):
        try:
            accounts = self.cfg.get('accounts', [])
            if not accounts:
                accounts = default_accounts()
            idx  = self.cfg.get('current_account_idx', 0) or 0
            acc  = accounts[idx % len(accounts)]
            resp, sid = _run_claude_image(path, prompt, self.cfg,
                                          acc.get('claude_dir'))
            GLib.idle_add(self._on_response, resp, sid,
                          acc.get('label', 'Cuenta principal'))
        except Exception as e:
            GLib.idle_add(self._on_error, f'Análisis de imagen: {e}')

    # ══════════════════════════════════════════════════════════════
    # INTEGRACIÓN 4: Drag & Drop de archivos
    # ══════════════════════════════════════════════════════════════
    def _on_drag_data(self, widget, ctx, x, y, data, info, time):
        uris  = data.get_uris()
        text  = data.get_text()
        Gtk.drag_finish(ctx, True, False, time)

        if uris:
            for uri in uris[:3]:           # máximo 3 archivos a la vez
                path = uri.replace('file://', '').strip()
                self._handle_dropped_file(path)
        elif text:
            buf = self._inp.get_buffer()
            buf.set_text(text)
            self._inp.grab_focus()

    def _handle_dropped_file(self, path: str):
        p    = Path(path)
        ext  = p.suffix.lower()
        acc  = self.cfg.get('accent', C_YELLOW)

        img_exts = {'.png', '.jpg', '.jpeg', '.gif', '.webp', '.bmp'}
        code_exts = {'.py', '.js', '.ts', '.rs', '.go', '.c', '.cpp',
                     '.h', '.java', '.rb', '.sh', '.bash', '.json',
                     '.yaml', '.yml', '.toml', '.sql', '.html', '.css',
                     '.md', '.txt', '.log', '.xml', '.csv'}

        if ext in img_exts:
            # Imagen → analizar como screenshot
            row, _ = _make_message_row(
                'user', f'[Imagen soltada: {p.name}]',
                self.cfg, self._ai_pb, self._user_pb)
            self._add_row(row)
            typ_row, _ = _make_typing_indicator(self.cfg)
            self._add_row(typ_row)
            self._typing_row = typ_row
            self._busy = True
            self._btn.set_sensitive(False)
            self._status.set_text(f'🖼 analizando {p.name}…')
            threading.Thread(
                target=self._screenshot_worker,
                args=(path, f'Analiza esta imagen: {p.name}'),
                daemon=True).start()

        elif ext == '.pdf':
            try:
                result = subprocess.run(['pdftotext', path, '-'],
                                        capture_output=True, text=True, timeout=15)
                content = result.stdout[:6000]
                buf = self._inp.get_buffer()
                buf.set_text(f'Analiza este PDF ({p.name}):\n\n{content}')
                self._show_drop_notice(p.name, 'PDF', acc)
            except Exception as e:
                self._show_drop_notice(p.name, f'Error: {e}', C_RED)

        elif ext in code_exts or p.stat().st_size < 200_000:
            try:
                content = p.read_text(errors='replace')[:8000]
                lang    = ext.lstrip('.') if ext else 'text'
                buf     = self._inp.get_buffer()
                buf.set_text(f'```{lang}\n{content}\n```\n\n')
                self._show_drop_notice(p.name, ext.lstrip('.') or 'texto', acc)
            except Exception as e:
                self._show_drop_notice(p.name, f'Error: {e}', C_RED)
        else:
            self._show_drop_notice(p.name, 'tipo no soportado', C_RED)

        self._inp.grab_focus()

    def _show_drop_notice(self, name: str, kind: str, color: str):
        lbl = Gtk.Label()
        lbl.set_markup(
            f'<span foreground="{color}" size="small">↓ {name} ({kind}) cargado</span>')
        lbl.set_halign(Gtk.Align.CENTER)
        lbl.set_margin_top(2); lbl.set_margin_bottom(2)
        lbl.show()
        self._chat_box.pack_start(lbl, False, False, 0)
        self._scroll_end()

    # ── Blur background ────────────────────────────────────────────
    def _window_rect(self):
        """Devuelve (x, y, w, h) donde aparecerá la ventana."""
        display = Gdk.Display.get_default()
        monitor = display.get_monitor(0)
        geom    = monitor.get_geometry()
        w, h    = 480, 660
        x = geom.x + geom.width - w - 6
        y = geom.y + 32
        return x, y, w, h

    def _capture_blur_bg(self, x, y, w, h):
        """Captura el área del escritorio y la difumina con PIL."""
        try:
            raw  = '/tmp/aurora_bg_raw.png'
            blur = '/tmp/aurora_bg_blur.png'
            # ffmpeg captura desde X11 (sin Aurora, que está oculta)
            subprocess.run([
                'ffmpeg', '-f', 'x11grab', '-video_size', f'{w}x{h}',
                '-i', f':0+{x},{y}', '-frames:v', '1', '-update', '1', '-y', raw,
            ], capture_output=True, timeout=4)
            if not Path(raw).exists():
                return
            img = Image.open(raw).convert('RGB')
            img = img.filter(ImageFilter.GaussianBlur(radius=18))
            img.save(blur)
            pb = GdkPixbuf.Pixbuf.new_from_file(blur)
            GLib.idle_add(self._set_blur_pb, pb)
        except Exception:
            pass

    def _set_blur_pb(self, pb):
        self._blur_pb = pb
        self.queue_draw()
        return False

    def _on_draw(self, widget, ctx):
        w = widget.get_allocated_width()
        h = widget.get_allocated_height()
        # Radio para las esquinas redondeadas
        r = 10
        # Clip con esquinas redondeadas
        ctx.new_sub_path()
        ctx.arc(r,     r,     r, math.pi,       1.5 * math.pi)
        ctx.arc(w - r, r,     r, 1.5 * math.pi, 2 * math.pi)
        ctx.arc(w - r, h - r, r, 0,              0.5 * math.pi)
        ctx.arc(r,     h - r, r, 0.5 * math.pi, math.pi)
        ctx.close_path()
        ctx.clip()

        if self._blur_pb:
            pb = self._blur_pb
            if pb.get_width() != w or pb.get_height() != h:
                pb = pb.scale_simple(w, h, GdkPixbuf.InterpType.BILINEAR)
            Gdk.cairo_set_source_pixbuf(ctx, pb, 0, 0)
            ctx.paint()
            # Overlay oscuro cyberpunk encima del blur
            ctx.set_source_rgba(0.024, 0.020, 0.055, 0.76)
            ctx.paint()
        else:
            # Sin blur aún: fondo sólido oscuro semitransparente
            op = self.cfg.get('window_opacity', 90) / 100
            ctx.set_source_rgba(0.024, 0.020, 0.055, op)
            ctx.paint()
        return False

    # ── Chat helpers ───────────────────────────────────────────────
    def _add_row(self, row: Gtk.Box):
        self._chat_box.pack_start(row, False, False, 0)
        self._scroll_end()

    def _scroll_end(self):
