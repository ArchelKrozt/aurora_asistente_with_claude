        dlg.add_button('Guardar archivo', 11)
        dlg.add_button('Cancelar', Gtk.ResponseType.CANCEL)
        dlg.show_all()
        resp = dlg.run(); dlg.destroy()

        if resp == 10:
            Gtk.Clipboard.get(Gdk.SELECTION_CLIPBOARD).set_text(md, -1)
            self._status.set_text('✔ Conversación copiada al portapapeles')
            GLib.timeout_add(3000, lambda: self._status.set_text('') or False)

        elif resp == 11:
            fc = Gtk.FileChooserDialog(
                title='Guardar conversación',
                parent=self, action=Gtk.FileChooserAction.SAVE)
            fc.add_button('Cancelar', Gtk.ResponseType.CANCEL)
            fc.add_button('Guardar',  Gtk.ResponseType.OK)
            ts   = datetime.now().strftime('%Y%m%d_%H%M')
            safe = self.conv.title[:30].replace('/', '-').replace(' ', '_')
            fc.set_current_name(f'aurora_{ts}_{safe}.md')
