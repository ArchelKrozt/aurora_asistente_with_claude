class Conversation:
    def __init__(self, cid=None):
        self.id         = cid or datetime.now().strftime('%Y%m%d_%H%M%S_%f')
        self.messages   = []
        self.title      = 'Nueva conversación'
        self.created    = datetime.now().isoformat()
        self.session_id = None
        self._path      = CONVS / f'{self.id}.json'
        if cid and self._path.exists():
            try:
                d = json.loads(self._path.read_text())
                self.messages   = d.get('messages', [])
                self.title      = d.get('title', self.title)
                self.created    = d.get('created', self.created)
                self.session_id = d.get('session_id')
            except: pass

    def save(self):
        self._path.write_text(json.dumps({
            'id':         self.id, 'title':      self.title,
            'created':    self.created,
            'session_id': self.session_id, 'messages': self.messages,
        }, indent=2, ensure_ascii=False))

    def add(self, role, content):
        self.messages.append({'role': role, 'content': content})
        if len(self.messages) == 2:
            self.title = self.messages[0]['content'][:55]
        self.save()

    @staticmethod
    def list_all():
        out = []
        for f in sorted(CONVS.glob('*.json'), reverse=True):
            try:
                d = json.loads(f.read_text())
                out.append({'id':      d.get('id', f.stem),
                            'title':   d.get('title', '—'),
                            'created': d.get('created', '')})
            except: pass
        return out

    @staticmethod
    def delete(cid: str):
        p = CONVS / f'{cid}.json'
        if p.exists():
            p.unlink()

    @staticmethod
    def rename(cid: str, new_title: str):
        p = CONVS / f'{cid}.json'
        if p.exists():
            d = json.loads(p.read_text())
            d['title'] = new_title
            p.write_text(json.dumps(d, indent=2, ensure_ascii=False))


