def _make_rich_bubble_content(text: str, cfg: Config) -> Gtk.Widget:
    """
    Construye contenido de burbuja con bloques de código enriquecidos.
    Retorna un Frame (texto simple) o VBox (contenido mixto).
    """
    segments = _parse_segments(text)
    has_code = any(s[0] == 'code' for s in segments)

    if not has_code:
        # Sin código: un solo TextView como antes
        tv = Gtk.TextView()
        tv.set_editable(False); tv.set_cursor_visible(False)
        tv.set_wrap_mode(Gtk.WrapMode.WORD_CHAR)
        tv.set_left_margin(10); tv.set_right_margin(10)
        tv.set_top_margin(7);   tv.set_bottom_margin(7)
        tv.get_style_context().add_class('bubble-text')
        buf = tv.get_buffer()
        _setup_bubble_tags(buf)
        buf.insert_with_tags_by_name(buf.get_end_iter(), text, 'normal')
        frame = Gtk.Frame(); frame.set_shadow_type(Gtk.ShadowType.NONE)
        frame.add(tv)
        return frame

    box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=4)
    box.set_margin_top(4); box.set_margin_bottom(4)

    for kind, content, *rest in segments:
        if kind == 'text':
            tv = Gtk.TextView()
            tv.set_editable(False); tv.set_cursor_visible(False)
            tv.set_wrap_mode(Gtk.WrapMode.WORD_CHAR)
            tv.set_left_margin(10); tv.set_right_margin(10)
            tv.set_top_margin(4);   tv.set_bottom_margin(4)
            tv.get_style_context().add_class('bubble-text')
            buf = tv.get_buffer()
            _setup_bubble_tags(buf)
            buf.insert_with_tags_by_name(buf.get_end_iter(), content, 'normal')
            frame = Gtk.Frame(); frame.set_shadow_type(Gtk.ShadowType.NONE)
            frame.add(tv)
            box.pack_start(frame, False, False, 0)
        else:
            lang = rest[0] if rest else ''
            cb   = _make_code_block_widget(content, lang)
            cb.get_style_context().add_class('code-block-outer')
            box.pack_start(cb, False, False, 0)
    return box


