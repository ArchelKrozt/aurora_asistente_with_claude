def _avatar_widget(pb: GdkPixbuf.Pixbuf) -> Gtk.Image:
    img = Gtk.Image.new_from_pixbuf(pb)
    img.set_valign(Gtk.Align.START)
    img.set_margin_top(2)
    return img


def _parse_segments(text: str) -> list:
    """Divide texto en segmentos ('text'|'code', contenido, lang)."""
    segments = []
    parts    = text.split('```')
    in_code  = False
    for part in parts:
        if in_code:
            lines = part.split('\n', 1)
            lang  = lines[0].strip() if lines else ''
            code  = lines[1].rstrip('\n') if len(lines) > 1 else ''
            if code:
                segments.append(('code', code, lang))
        else:
            if part.strip():
                segments.append(('text', part))
        in_code = not in_code
    return segments or [('text', text)]


def _make_code_block_widget(code: str, lang: str) -> Gtk.Widget:
    """Widget enriquecido para un bloque de código con botón Copiar."""
