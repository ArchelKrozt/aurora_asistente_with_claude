        uname = self.cfg.get('user_name', 'Tú')
        lines = [f'# Conversación con {name}',
                 f'*{self.conv.created[:16].replace("T", " ")}*\n']
        for m in self.conv.messages:
            who = name if m['role'] == 'assistant' else uname
            lines.append(f'### {who}\n{m["content"]}\n')
        md = '\n'.join(lines)

        dlg = Gtk.Dialog(title='Exportar conversación',
                         parent=self, modal=True)
        dlg.set_default_size(340, 140)
