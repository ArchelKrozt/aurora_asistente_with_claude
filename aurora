def find_claude() -> str | None:
    c = shutil.which('claude')
    if c: return c
    nvm = Path.home() / '.nvm'
    if nvm.exists():
        for p in sorted(nvm.glob('versions/node/*/bin/claude'), reverse=True):
            if p.is_file(): return str(p)
    for p in [Path.home() / '.npm-global/bin/claude',
               Path('/usr/local/bin/claude')]:
        if p.is_file(): return str(p)
    return None

CLAUDE_BIN = find_claude()


def _ext_path() -> str:
    extra = []
    nvm = Path.home() / '.nvm'
    if nvm.exists():
        for p in sorted(nvm.glob('versions/node/*/bin'), reverse=True):
            extra.append(str(p))
    extra += [str(Path.home() / '.npm-global/bin'),
              str(Path.home() / '.local/bin'),
              '/usr/local/bin', '/usr/bin', '/bin']
    return ':'.join(extra + [os.environ.get('PATH', '')])


