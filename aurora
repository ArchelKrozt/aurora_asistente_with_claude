    # ── Envío ──────────────────────────────────────────────────────
    def _on_key(self, widget, event):
        shift = bool(event.state & Gdk.ModifierType.SHIFT_MASK)
        if event.keyval in (Gdk.KEY_Return, Gdk.KEY_KP_Enter) and not shift:
            self._send()
            return True
        # Mostrar/ocultar slash popup al escribir
        GLib.idle_add(self._update_slash_popup)
        return False

    # ══════════════════════════════════════════════════════════════
    # SLASH COMMANDS — autocompletado
    # ══════════════════════════════════════════════════════════════
    def _update_slash_popup(self):
        buf  = self._inp.get_buffer()
        text = buf.get_text(buf.get_start_iter(), buf.get_end_iter(), False)
        if not text.startswith('/'):
            self._hide_slash_popup()
            return False
        query   = text[1:].lower()
        cmds    = [c for c in get_commands(self.cfg)
                   if c['trigger'].startswith(query)]
        if not cmds:
            self._hide_slash_popup()
            return False
        self._show_slash_popup(cmds)
        return False

    def _show_slash_popup(self, cmds: list):
        if not hasattr(self, '_slash_popup') or not self._slash_popup:
            self._slash_popup = Gtk.Popover()
            self._slash_popup.set_relative_to(self._inp)
            self._slash_popup.set_position(Gtk.PositionType.TOP)
            self._slash_popup.set_modal(False)
            self._slash_popup.get_style_context().add_class('slash-popup')

        # Reconstruir lista
        child = self._slash_popup.get_child()
        if child:
            self._slash_popup.remove(child)

        lb = Gtk.ListBox()
        lb.set_selection_mode(Gtk.SelectionMode.BROWSE)
        lb.get_style_context().add_class('slash-popup')

        for cmd in cmds[:8]:
            row = Gtk.ListBoxRow()
            lbl = Gtk.Label(label=cmd['label'])
            lbl.get_style_context().add_class('slash-row')
            lbl.set_halign(Gtk.Align.START)
            row._cmd = cmd
            row.add(lbl)
            lb.add(row)

        lb.select_row(lb.get_row_at_index(0))

        def on_row_activated(lb, row):
            self._apply_slash_command(row._cmd)

        lb.connect('row-activated', on_row_activated)
        self._slash_lb = lb
        self._slash_popup.add(lb)
        self._slash_popup.show_all()

    def _hide_slash_popup(self):
        if hasattr(self, '_slash_popup') and self._slash_popup:
            self._slash_popup.popdown()

    def _apply_slash_command(self, cmd: dict):
        self._hide_slash_popup()
        if cmd['prompt'] == '__TERMINAL__':
            self._inp.get_buffer().set_text('/run ')
            self._inp.grab_focus()
            return
        if cmd['prompt'] == '__SUDO__':
            self._inp.get_buffer().set_text('/sudo ')
            self._inp.grab_focus()
            return
        self._inp.get_buffer().set_text(cmd['prompt'])
        self._inp.grab_focus()
        # Colocar cursor al final
        buf = self._inp.get_buffer()
        buf.place_cursor(buf.get_end_iter())

    def _send(self, *_):
        if self._busy: return
        self._hide_slash_popup()
        if not CLAUDE_BIN:
            self._show_no_cli()
            return
        ib   = self._inp.get_buffer()
        text = ib.get_text(ib.get_start_iter(), ib.get_end_iter(), False).strip()
        if not text: return

        # ── Modo terminal (/run <cmd>) ─────────────────────────
        if text.startswith('/run ') or text.startswith('/sudo '):
            prefix_len = 5 if text.startswith('/run ') else 6
            cmd = text[prefix_len:].strip()
            if not cmd:
                return
            ib.set_text('')
            # Si el comando empieza con "sudo ", extraer y usar ruta sudo
            if cmd.startswith('sudo '):
                cmd = cmd[5:].strip()
                self._run_terminal_command(cmd, use_sudo=True)
            else:
                use_sudo = text.startswith('/sudo ')
                self._run_terminal_command(cmd, use_sudo=use_sudo)
            return

        ib.set_text('')

        # Mensaje del usuario
        row, _ = _make_message_row('user', text, self.cfg,
                                   self._ai_pb, self._user_pb)
        self._add_row(row)
        self.conv.add('user', text)

        # Indicador "procesando"
        self._typing_row, _ = _make_typing_indicator(self.cfg)
        self._add_row(self._typing_row)

        self._busy = True
        self._btn.set_sensitive(False)
        self._status.set_text('⚡ procesando…')

        threading.Thread(target=self._worker,
                         args=(text, self.conv.session_id),
                         daemon=True).start()

    def _worker(self, message: str, session_id: str | None):
        def _on_compact(active: bool):
            GLib.idle_add(self._show_compact_bar if active else self._hide_compact_bar)
        try:
            resp, sid, acc_label = call_claude(message, session_id, self.cfg,
                                               on_compact=_on_compact)
            GLib.idle_add(self._on_response, resp, sid, acc_label)
        except Exception as e:
            GLib.idle_add(self._hide_compact_bar)
            GLib.idle_add(self._on_error, str(e))

    def _on_response(self, text: str, sid: str, acc_label: str):
        # Eliminar indicador
        if self._typing_row:
            self._chat_box.remove(self._typing_row)
            self._typing_row = None

        self.conv.session_id = sid
        self.conv.add('assistant', text)

        # Mostrar qué cuenta se usó si no es la principal
        accounts = self.cfg.get('accounts', [])
        idx = self.cfg.get('current_account_idx', 0) or 0
        main_label = accounts[0].get('label') if accounts else None
        if acc_label and main_label and acc_label != main_label:
            self._status.set_text(f'⚡ usando: {acc_label}')
        else:
            self._status.set_text('')

        # Burbuja de respuesta vacía para animar (streaming)
        row, tv = _make_message_row('assistant', '', self.cfg,
                                    self._ai_pb, self._user_pb,
                                    streaming=True)
        self._add_row(row)
        self._stream_row = row
        self._stream_tv  = tv
        self._stream_buf = tv.get_buffer()
        _setup_bubble_tags(self._stream_buf)
        self._anim_text = text
        self._anim_pos  = 0
        GLib.timeout_add(5, self._anim_tick)
        return False

    def _anim_tick(self):
        if self._anim_pos >= len(self._anim_text):
            # Animación terminada — reconstruir burbuja con código enriquecido
            self._finalize_bubble(self._stream_row, self._anim_text)
            self._busy = False
            self._btn.set_sensitive(True)
            self._stream_tv = self._stream_buf = self._stream_row = None
            self._scroll_end()
            return False
        n     = self.cfg.get('anim_speed', 4)
        chunk = self._anim_text[self._anim_pos:self._anim_pos + n]
        end   = self._stream_buf.get_end_iter()
        self._stream_buf.insert_with_tags_by_name(end, chunk, 'normal')
        self._anim_pos += n
        self._scroll_end()
        return True

    def _finalize_bubble(self, row: Gtk.Box, text: str):
        """Reemplaza el TextView de streaming por contenido enriquecido."""
        if not row or not text:
            return
        # Estructura del row: [avatar/spacer, content_box, spacer/avatar]
        # content_box es el hijo HExpand=True
        content_box = None
        for child in row.get_children():
            if child.get_hexpand():
                content_box = child
                break
        if not content_box:
            return

        # El último hijo de content_box es el bubble frame (streaming)
        kids = content_box.get_children()
        if not kids:
            return
        old_bubble = kids[-1]

        # Construir contenido enriquecido
        rich = _make_rich_bubble_content(text, self.cfg)
        is_ai = True  # siempre es respuesta del asistente aquí
        rich.get_style_context().add_class('bubble-ai')
        rich.show_all()

        content_box.remove(old_bubble)
        content_box.pack_start(rich, True, True, 0)

    def _on_error(self, msg: str):
        if self._typing_row:
            self._chat_box.remove(self._typing_row)
            self._typing_row = None
        row, _ = _make_message_row('assistant',
                                   f'[Error de conexión: {msg}]',
                                   self.cfg, self._ai_pb, self._user_pb)
        self._add_row(row)
        self._busy = False
        self._btn.set_sensitive(True)
        self._status.set_text('')
        return False

    # ══════════════════════════════════════════════════════════════
    # MODO TERMINAL — /run y /sudo
    # ══════════════════════════════════════════════════════════════
    def _run_terminal_command(self, cmd: str, use_sudo: bool = False):
        if use_sudo:
            # Verificar si NOPASSWD está configurado
            if not SUDO_MGR.is_nopasswd():
                self._show_sudo_setup_dialog(cmd)
                return
        elif self.cfg.get('terminal_confirm', True):
            dlg = Gtk.MessageDialog(
                parent=self, modal=True,
                message_type=Gtk.MessageType.WARNING,
                buttons=Gtk.ButtonsType.OK_CANCEL,
                text='Ejecutar comando')
            dlg.format_secondary_markup(
                f'<tt>{GLib.markup_escape_text(cmd)}</tt>\n\n'
                '¿Confirmas la ejecución?')
            resp = dlg.run(); dlg.destroy()
            if resp != Gtk.ResponseType.OK:
                return

        prefix   = '# ' if use_sudo else '$ '
        row_u, _ = _make_message_row('user', f'{prefix}{cmd}',
                                     self.cfg, self._ai_pb, self._user_pb)
        self._add_row(row_u)
        self._busy = True
        self._btn.set_sensitive(False)
        self._status.set_text('⚡ ejecutando…')

        threading.Thread(target=self._terminal_worker,
                         args=(cmd, use_sudo),
                         daemon=True).start()

