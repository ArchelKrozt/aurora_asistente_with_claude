def _make_circular_pixbuf(path: str | None, size: int = 36) -> GdkPixbuf.Pixbuf | None:
    """Carga imagen y aplica clip circular con Cairo."""
    try:
        surf = cairo.ImageSurface(cairo.FORMAT_ARGB32, size, size)
        ctx  = cairo.Context(surf)
        ctx.arc(size / 2, size / 2, size / 2, 0, 2 * math.pi)
        ctx.clip()
        pb = GdkPixbuf.Pixbuf.new_from_file_at_size(path, size, size)
        Gdk.cairo_set_source_pixbuf(ctx, pb, 0, 0)
        ctx.paint()
        return Gdk.pixbuf_get_from_surface(surf, 0, 0, size, size)
    except Exception:
        return None

def _default_pixbuf(color: str, size: int = 36, letter: str = '?') -> GdkPixbuf.Pixbuf:
    """Avatar por defecto con inicial."""
    surf = cairo.ImageSurface(cairo.FORMAT_ARGB32, size, size)
    ctx  = cairo.Context(surf)
    ctx.arc(size / 2, size / 2, size / 2, 0, 2 * math.pi)
    ctx.clip()
    # Fondo
    ctx.set_source_rgba(0.04, 0.03, 0.09, 0.95)
    ctx.paint()
    # Borde
    def hex2rgb(h):
        h = h.lstrip('#')
        return tuple(int(h[i:i+2], 16) / 255 for i in (0, 2, 4))
    r, g, b = hex2rgb(color)
    ctx.set_source_rgba(r, g, b, 0.8)
    ctx.set_line_width(2)
    ctx.arc(size / 2, size / 2, size / 2 - 1, 0, 2 * math.pi)
    ctx.stroke()
    # Letra
    ctx.set_source_rgba(r, g, b, 1)
    ctx.select_font_face('Monospace', cairo.FONT_SLANT_NORMAL, cairo.FONT_WEIGHT_BOLD)
    ctx.set_font_size(size * 0.44)
    te = ctx.text_extents(letter)
    ctx.move_to(size / 2 - te.width / 2 - te.x_bearing,
                size / 2 - te.height / 2 - te.y_bearing)
    ctx.show_text(letter)
    return Gdk.pixbuf_get_from_surface(surf, 0, 0, size, size)

def load_pixbufs(cfg: Config):
    ai_path   = cfg.get('aurora_avatar')
    user_path = cfg.get('user_avatar')
    ai_pb   = (_make_circular_pixbuf(ai_path, 36)
                if ai_path and Path(ai_path).exists() else None)
    user_pb = (_make_circular_pixbuf(user_path, 36)
                if user_path and Path(user_path).exists() else None)
    if not ai_pb:
        ai_pb   = _default_pixbuf(C_RED,    36, 'A')
    if not user_pb:
        user_name = cfg.get('user_name', 'Tú')
        user_pb = _default_pixbuf(C_YELLOW, 36, user_name[0].upper())
    return ai_pb, user_pb


