def _setup_bubble_tags(buf: Gtk.TextBuffer):
    buf.create_tag('normal', foreground='#dcdce4')
    buf.create_tag('code',   foreground='#fcee09', background='#0e0c20',
                   family='Monospace', left_margin=4, right_margin=4,
                   pixels_above_lines=2, pixels_below_lines=2)
    buf.create_tag('bold',   foreground='#ffffff', weight=Pango.Weight.BOLD)


def _fill_bubble(buf: Gtk.TextBuffer, text: str):
    """Inserta texto en el buffer diferenciando bloques de código."""
    buf.set_text('')
    end = buf.get_end_iter
    parts = text.split('```')
    in_code = False
    for part in parts:
        if in_code:
            lines = part.split('\n', 1)
            body  = lines[1] if len(lines) > 1 else part
            if body:
                buf.insert_with_tags_by_name(end(), body, 'code')
        else:
            if part:
                buf.insert_with_tags_by_name(end(), part, 'normal')
        in_code = not in_code


def _make_message_row(role: str, text: str, cfg: Config,
                      ai_pb: GdkPixbuf.Pixbuf,
                      user_pb: GdkPixbuf.Pixbuf,
                      streaming: bool = False) -> tuple[Gtk.Box, Gtk.TextView | None]:
    """
    Construye una fila de mensaje completa.
    Retorna (row_widget, textview_or_None).
    textview es None si no es streaming.
    """
    is_ai   = (role == 'assistant')
    acc_col = cfg.get('accent', C_YELLOW)
    show_ts = cfg.get('show_timestamp', True)
    name    = (cfg.get('aurora_name', 'Aurora') if is_ai
               else cfg.get('user_name', 'Tú'))

    row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
