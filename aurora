    def _setup_clipboard_monitor(self):
        if not self.cfg.get('clipboard_monitor', True):
            return
        self._clip = Gtk.Clipboard.get(Gdk.SELECTION_CLIPBOARD)
        self._clip.connect('owner-change', self._on_clipboard_change)
        self._last_clip_text = ''

    def _on_clipboard_change(self, clipboard, event):
        if self._busy:
            return
        text = clipboard.wait_for_text()
        if not text:
            return
        min_chars = self.cfg.get('clipboard_min_chars', 80)
        if len(text) < min_chars:
            return
        if text == self._last_clip_text:
            return
        self._last_clip_text = text
        GLib.idle_add(self._show_clip_popup, text)

    def _show_clip_popup(self, text: str):
        # Eliminar popup anterior si existe
        if hasattr(self, '_clip_popup') and self._clip_popup:
            self._chat_box.remove(self._clip_popup)
            self._clip_popup = None

        popup = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=4)
        popup.set_margin_start(10); popup.set_margin_end(10)
        popup.set_margin_top(4);    popup.set_margin_bottom(4)

        acc = self.cfg.get('accent', C_YELLOW)

        # Preview del texto copiado
        preview = text[:120] + ('…' if len(text) > 120 else '')
        prev_lbl = Gtk.Label(label=preview)
        prev_lbl.set_line_wrap(True)
        prev_lbl.set_max_width_chars(55)
        prev_lbl.set_halign(Gtk.Align.START)
        prev_lbl.set_markup(
            f'<span foreground="#aaaacc" size="small">📋 {GLib.markup_escape_text(preview)}</span>')
        popup.pack_start(prev_lbl, False, False, 0)

        btns = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=6)

        def on_analyze(_):
            self._inp.get_buffer().set_text('')
            # Pre-cargar el texto en el input con contexto
            buf = self._inp.get_buffer()
            buf.set_text(f'Analiza este texto:\n\n{text}')
            self._chat_box.remove(popup)
            self._clip_popup = None
            popup.destroy()

        def on_ask(_):
            buf = self._inp.get_buffer()
            existing = buf.get_text(buf.get_start_iter(), buf.get_end_iter(), False)
            if not existing:
                buf.set_text(text)
            self._chat_box.remove(popup)
            self._clip_popup = None
            popup.destroy()
            self._inp.grab_focus()

        def on_dismiss(_):
            self._chat_box.remove(popup)
            self._clip_popup = None
            popup.destroy()

        for lbl, fn in [('Analizar', on_analyze),
                         ('Usar como contexto', on_ask),
                         ('✕', on_dismiss)]:
            b = Gtk.Button(label=lbl)
            b.get_style_context().add_class('aurora-btn-sm')
            b.connect('clicked', fn)
            btns.pack_start(b, False, False, 0)

        popup.pack_start(btns, False, False, 0)
        popup.get_style_context().add_class('bubble-ai')
        popup.show_all()

        self._clip_popup = popup
        self._chat_box.pack_start(popup, False, False, 0)
        self._scroll_end()
        # Mostrar la ventana si estaba oculta
        if not self.get_visible():
            self._position()
            self.show_all()
            self.present()
        return False

