        )
        self._typing_row, _ = _make_typing_indicator(self.cfg)
        self._add_row(self._typing_row)
        self._status.set_text('⚡ analizando output…')

        threading.Thread(target=self._worker,
                         args=(analysis_prompt, self.conv.session_id),
