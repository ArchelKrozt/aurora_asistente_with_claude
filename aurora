    def _pick_avatar(self, target: str, parent):
        fc = Gtk.FileChooserDialog(
            title='Selecciona imagen', parent=parent,
            action=Gtk.FileChooserAction.OPEN)
        fc.add_button('Cancelar', Gtk.ResponseType.CANCEL)
        fc.add_button('Abrir',    Gtk.ResponseType.OK)
        ff = Gtk.FileFilter()
        ff.set_name('Imágenes (PNG, JPG, SVG)')
        for p in ('image/png', 'image/jpeg', 'image/svg+xml'):
            ff.add_mime_type(p)
        fc.add_filter(ff)

        if fc.run() == Gtk.ResponseType.OK:
            path = fc.get_filename()
            if target == 'aurora':
                self.cfg.set('aurora_avatar', path)
                pb = (_make_circular_pixbuf(path, 40)
                      or _default_pixbuf(C_RED, 40, 'A'))
                self._ai_prev.set_from_pixbuf(pb)
            else:
                self.cfg.set('user_avatar', path)
                pb = (_make_circular_pixbuf(path, 40)
                      or _default_pixbuf(C_YELLOW, 40, 'T'))
                self._usr_prev.set_from_pixbuf(pb)
        fc.destroy()

    # ── Toggle ─────────────────────────────────────────────────────
    def toggle(self):
        if self.get_visible():
            self.hide()
        else:
            self._position()
            # Capturar fondo ANTES de mostrar la ventana (no aparece en screenshot)
            x, y, w, h = self._window_rect()
            threading.Thread(
                target=self._capture_blur_bg, args=(x, y, w, h), daemon=True
            ).start()
            self.show_all()
            self.present()
            self._inp.grab_focus()


