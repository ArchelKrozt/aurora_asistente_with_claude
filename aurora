        clip_lbl = Gtk.Label()
        clip_lbl.set_markup(
            '<b>Monitor de portapapeles</b>\n'
            '<small>Detecta texto copiado y ofrece analizarlo con Aurora.</small>')
        clip_lbl.set_line_wrap(True); clip_lbl.set_halign(Gtk.Align.START)
        t6.pack_start(clip_lbl, False, False, 0)

        clip_check = Gtk.CheckButton(label='Monitorear portapapeles')
        clip_check.set_active(self.cfg.get('clipboard_monitor', True))
        t6.pack_start(clip_check, False, False, 4)

