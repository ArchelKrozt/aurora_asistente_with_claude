        verify_status = Gtk.Label(label='')
        verify_status.get_style_context().add_class('dlg-sub')

        def on_verify(_):
            new_dir   = _new_acc_dir()
            new_label = new_label_e.get_text().strip() or f'Cuenta {len(self.cfg.get("accounts",[]))+1}'
            creds     = read_account_creds(new_dir)
            if creds.get('valid'):
                accs2 = self.cfg.get('accounts', [])
                accs2.append({
                    'id':            f'account{len(accs2)+1}',
                    'label':         new_label,
                    'claude_dir':    new_dir,
                    'plan':          creds.get('plan', '?'),
                    'enabled':       True,
                    'depleted_until': None,
                })
                self.cfg.save_all({'accounts': accs2})
                new_label_e.set_text('')
                cmd_tv.set_text(f'CLAUDE_CONFIG_DIR={_new_acc_dir()} claude login')
                verify_status.set_markup(
                    f'<span foreground="#00e5ff">✔ Cuenta "{new_label}" agregada ({creds["plan"]})</span>')
                refresh_accounts_ui()
            else:
                verify_status.set_markup(
                    '<span foreground="#FF003C">✗ No se encontraron credenciales. '
                    'Ejecuta el comando de arriba primero.</span>')

        verify_btn.connect('clicked', on_verify)
        t5.pack_start(verify_btn,    False, False, 4)
        t5.pack_start(verify_status, False, False, 0)

        # ── Tab 6: Sistema ────────────────────────────────────
        t6 = page('Sistema')
        hotkey_lbl = Gtk.Label()
        hotkey_lbl.set_markup(
            '<b>Hotkey global</b>\n'
            '<small>Ctrl+Alt+Space — muestra/oculta Aurora desde cualquier app.</small>')
        hotkey_lbl.set_line_wrap(True); hotkey_lbl.set_halign(Gtk.Align.START)
        t6.pack_start(hotkey_lbl, False, False, 0)

