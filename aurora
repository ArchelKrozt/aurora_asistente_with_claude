class Aurora:
    def __init__(self):
        self.cfg = Config()
        self.win = AuroraWindow(self.cfg)
        self._setup_indicator()

    def _setup_indicator(self):
        ICON.write_text(ICON_SVG)
        if HAS_INDICATOR:
            self.ind = AppIndicator3.Indicator.new(
                'aurora-assistant', str(ICON),
                AppIndicator3.IndicatorCategory.APPLICATION_STATUS)
            self.ind.set_status(AppIndicator3.IndicatorStatus.ACTIVE)
            self.ind.set_menu(self._menu())
        else:
            si = Gtk.StatusIcon()
            try:
                loader = GdkPixbuf.PixbufLoader.new_with_type('svg')
                loader.write(ICON_SVG.encode())
                loader.close()
                pb = loader.get_pixbuf().scale_simple(
                    22, 22, GdkPixbuf.InterpType.BILINEAR)
                si.set_from_pixbuf(pb)
            except:
                si.set_from_icon_name('dialog-information',
                                      Gtk.IconSize.SMALL_TOOLBAR)
            si.set_tooltip_text('Aurora')
            si.connect('activate', lambda _: self.win.toggle())
            self._si = si

    def _menu(self):
        m = Gtk.Menu()
        for lbl, fn in [
            ('⚡  Aurora',       lambda _: self.win.toggle()),
            ('＋  Nueva sesión', lambda _: (self.win.show_all(), self.win._new_conv())),
            ('🕐  Historial',    lambda _: (self.win.show_all(), self.win._show_history())),
            (None, None),
            ('Salir', lambda _: Gtk.main_quit()),
        ]:
            if lbl is None: m.append(Gtk.SeparatorMenuItem())
            else:
                it = Gtk.MenuItem(label=lbl)
                it.connect('activate', fn)
                m.append(it)
        m.show_all()
        return m

    def run(self):
        if not CLAUDE_BIN:
            d = Gtk.MessageDialog(parent=self.win, modal=True,
                type=Gtk.MessageType.ERROR, buttons=Gtk.ButtonsType.OK,
                text='CLI de Claude no encontrado',
                secondary_text='npm install -g @anthropic-ai/claude-code')
            d.run(); d.destroy()
        Gtk.main()


if __name__ == '__main__':
    Aurora().run()
