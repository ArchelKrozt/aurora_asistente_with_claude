        # ── Tab 5: Cuentas ────────────────────────────────────
        t5 = page('Cuentas')
        accounts_list_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)

        def refresh_accounts_ui():
            for ch in accounts_list_box.get_children():
                accounts_list_box.remove(ch)
            accs = self.cfg.get('accounts', [])
            if not accs:
                accs = default_accounts()
                self.cfg.set('accounts', accs)
            now = datetime.now().timestamp()
            cur = self.cfg.get('current_account_idx', 0) or 0

            for i, ac in enumerate(accs):
                creds = read_account_creds(ac.get('claude_dir', ''))
                dep   = ac.get('depleted_until')
                active_now = not (dep and now < dep)

                row_box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=6)
                row_box.set_margin_top(4); row_box.set_margin_bottom(4)
                row_box.set_margin_start(4); row_box.set_margin_end(4)

                # Indicador de estado
                dot = Gtk.Label()
                if i == cur:
                    dot.set_markup('<span foreground="#fcee09">●</span>')
                elif not active_now:
                    dot.set_markup('<span foreground="#FF003C">●</span>')
                elif not ac.get('enabled', True):
                    dot.set_markup('<span foreground="#555">●</span>')
                else:
                    dot.set_markup('<span foreground="#00e5ff">●</span>')
                row_box.pack_start(dot, False, False, 0)

                # Info
                vb2 = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=1)
                name_lbl = Gtk.Label(label=ac.get('label', f'Cuenta {i+1}'))
                name_lbl.get_style_context().add_class('dlg-title')
                name_lbl.set_halign(Gtk.Align.START)
                plan   = creds.get('plan', ac.get('plan', '?'))
                status = ('activa' if active_now else
                          f'agotada {int((dep - now)/60):.0f} min')
                detail = f'{plan}  •  {status}'
                if i == cur:
                    detail += '  ★ en uso'
                detail_lbl = Gtk.Label(label=detail)
                detail_lbl.get_style_context().add_class('dlg-sub')
                detail_lbl.set_halign(Gtk.Align.START)
                vb2.pack_start(name_lbl,   False, False, 0)
                vb2.pack_start(detail_lbl, False, False, 0)
                row_box.pack_start(vb2, True, True, 0)

                # Botones
                if i != cur:
                    use_btn = Gtk.Button(label='Usar')
                    use_btn.get_style_context().add_class('aurora-btn-sm')
                    use_btn._acc_idx = i
                    def on_use(b, idx=i):
                        self.cfg.set('current_account_idx', idx)
                        refresh_accounts_ui()
                    use_btn.connect('clicked', on_use)
                    row_box.pack_start(use_btn, False, False, 0)

                if dep and now < dep:
                    rst_btn = Gtk.Button(label='Resetear')
                    rst_btn.get_style_context().add_class('aurora-btn-sm')
                    def on_reset(b, idx=i):
                        accs2 = self.cfg.get('accounts', [])
                        accs2[idx]['depleted_until'] = None
                        self.cfg.save_all({'accounts': accs2})
                        refresh_accounts_ui()
                    rst_btn.connect('clicked', on_reset)
                    row_box.pack_start(rst_btn, False, False, 0)

                if i != 0 or len(accs) > 1:
                    del_btn = Gtk.Button(label='✕')
                    del_btn.get_style_context().add_class('aurora-btn-sm')
                    def on_del(b, idx=i):
