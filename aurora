        color = '#FF003C' if use_sudo else '#00e5ff'
        rc_ok = rc == 0
        hdr   = Gtk.Label()
        hdr.set_markup(
            f'<span foreground="{color}" size="small" weight="bold">{tag}</span>'
            f'  <span foreground="{"#00e5ff" if rc_ok else "#FF003C"}" size="small">'
            f'exit {rc}</span>')
        hdr.set_halign(Gtk.Align.START)
        content.pack_start(hdr, False, False, 0)

        tv = Gtk.TextView()
        tv.set_editable(False); tv.set_cursor_visible(False)
        tv.set_wrap_mode(Gtk.WrapMode.WORD_CHAR)
        tv.set_left_margin(10); tv.set_right_margin(10)
        tv.set_top_margin(6);   tv.set_bottom_margin(6)
        tv.get_style_context().add_class('terminal-tv')
        tv.get_buffer().set_text(output[:4000])

        frame = Gtk.Frame(); frame.set_shadow_type(Gtk.ShadowType.NONE)
        frame.get_style_context().add_class('terminal-bubble')
