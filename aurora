                fc.set_current_folder(export_dir)
            if fc.run() == Gtk.ResponseType.OK:
                Path(fc.get_filename()).write_text(md, encoding='utf-8')
                self._status.set_text(f'✔ Guardado en {fc.get_filename()}')
                GLib.timeout_add(4000, lambda: self._status.set_text('') or False)
