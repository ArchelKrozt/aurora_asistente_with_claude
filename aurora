    # ══════════════════════════════════════════════════════════════
    # SYSMON — stats CPU/RAM en tiempo real
    # ══════════════════════════════════════════════════════════════
    def _setup_sysmon(self):
        if not self.cfg.get('show_sysmon', True):
            return
        GLib.timeout_add(2000, self._tick_sysmon)

    def _tick_sysmon(self):
        try:
            cpu  = psutil.cpu_percent(interval=None)
            ram  = psutil.virtual_memory()
            net  = psutil.net_io_counters()
            rx   = getattr(self, '_last_rx', net.bytes_recv)
            tx   = getattr(self, '_last_tx', net.bytes_sent)
            drx  = (net.bytes_recv - rx) / 2048  # KB/s
            dtx  = (net.bytes_sent - tx) / 2048
            self._last_rx = net.bytes_recv
            self._last_tx = net.bytes_sent

            def bar(pct, width=8):
                filled = int(pct / 100 * width)
                return '█' * filled + '░' * (width - filled)

            txt = (f'CPU {bar(cpu)} {cpu:4.1f}%   '
                   f'RAM {bar(ram.percent)} {ram.percent:4.1f}%   '
                   f'↓{drx:5.1f} ↑{dtx:5.1f} KB/s')
            self._sysmon_lbl.set_text(txt)
        except Exception:
            pass
        return self.cfg.get('show_sysmon', True)  # continuar o detener

