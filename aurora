class SudoManager:
    def __init__(self):
        self._lock = threading.Lock()

    def is_nopasswd(self) -> bool:
        """Verifica si NOPASSWD está configurado (sin prompt)."""
        r = subprocess.run(['sudo', '-n', 'true'],
                           capture_output=True, timeout=5)
        return r.returncode == 0

    def run(self, cmd: str, env: dict | None = None) -> tuple[str, int]:
        """Ejecuta cmd con sudo -n (requiere NOPASSWD configurado)."""
        run_env = {**os.environ, 'PATH': _ext_path(), **(env or {})}
        proc = subprocess.run(
            f'sudo -n -- {cmd}',
            shell=True, capture_output=True, text=True,
            timeout=60, env=run_env)
        return (proc.stdout + proc.stderr).strip(), proc.returncode

    def invalidate(self):
        pass   # con NOPASSWD ya no hay caché que manejar


