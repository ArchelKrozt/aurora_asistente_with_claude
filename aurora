class Config:
    def __init__(self):
        self._d = dict(DEFAULTS)
        if CFG.exists():
            try: self._d.update(json.loads(CFG.read_text()))
            except: pass

    def get(self, k, default=None):
        return self._d.get(k, DEFAULTS.get(k, default))

    def set(self, k, v):
        self._d[k] = v
        CFG.write_text(json.dumps(self._d, indent=2))

    def save_all(self, d: dict):
        self._d.update(d)
        CFG.write_text(json.dumps(self._d, indent=2))


