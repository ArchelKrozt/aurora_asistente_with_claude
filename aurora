        spacer = Gtk.Box(); spacer.set_size_request(60, -1)
        outer.pack_start(content, True, True, 0)
        outer.pack_start(spacer,  False, False, 0)
        outer.show_all()
        self._chat_box.pack_start(outer, False, False, 0)
        self._scroll_end()

        # Auto-enviar output a Claude para análisis
        analysis_prompt = (
            f'Ejecuté el comando: `{cmd}`\n'
